#!/bin/bash

# Shows help, examples, and defaults. Called on --help or invalid input.
usage() {
  cat <<EOF
Usage: $(basename "$0") [OPTIONS]

Options:
  --device <path>             Target disk device (default: /dev/sda)
  --os-size <size>            Size of OS partition (default: 50G)
  --boot <bios|uefi>          Boot mode (default: bios)
  --home-encryption <value>   Password to enable home encryption
  -h, --help                  Show this help and exit

Examples:
  $(basename "$0") --device /dev/sdb --os-size 100G
  $(basename "$0") --boot uefi
  $(basename "$0") --home-encryption secret

WARNING:
  This script modifies disks → DATA LOSS ⚠️
EOF
}

# Arguments
DEVICE="/dev/sda"
OS_SIZE="50G"
BOOT="bios"
HOME_ENCRYPTION=""

# Constants
CRYPT_NAME="encrypted-home"
EFI_SIZE="512MiB"
ARCH_MOUNT_POINT="/mnt"

# Argument parsing
while [[ $# -gt 0 ]]; do
  case "$1" in
    --device)
      [[ -z "$2" ]] && echo "Missing value for --device" && usage && exit 1
      DEVICE="$2"
      shift 2
      ;;
    --os-size)
      [[ -z "$2" ]] && echo "Missing value for --os-size" && usage && exit 1
      OS_SIZE="$2"
      shift 2
      ;;
    --boot)
      [[ -z "$2" ]] && echo "Missing value for --boot" && usage && exit 1
      BOOT="$2"
      if [[ "$BOOT" != "bios" ]] && [[ "$BOOT" != "uefi" ]]; then
        echo "Invalid value for --boot: $BOOT"
        echo "Allowed values: bios | uefi"
        usage
        exit 1
      fi
      shift 2
      ;;
    --home-encryption)
      [[ -z "$2" ]] && echo "Missing value for --home-encryption" && usage && exit 1
      HOME_ENCRYPTION="$2"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    -*)
      echo "Unknown option: $1"
      usage
      exit 1
      ;;
    *)
      echo "Unexpected argument: $1"
      usage
      exit 1
      ;;
  esac
done

# Debug
echo "--------------------------------------------------------------------------------"
echo "Device: $DEVICE"
echo "OS size: $OS_SIZE"
echo "Boot mode: $BOOT"
echo "Mount point: $ARCH_MOUNT_POINT"
echo "Home encryption: ${HOME_ENCRYPTION:-disabled}"
echo "================================================================================"

if [[ "$BOOT" == "uefi" ]]; then
  # UEFI layout:
  # 1 -> EFI System Partition (FAT32, 512 MiB)
  # 2 -> OS partition
  # 3 -> Home partition
  echo -e "g\nn\n1\n\n+${EFI_SIZE}\nt\n1\nuefi\nn\n2\n\n+${OS_SIZE}\nn\n3\n\n\nw\n" | fdisk "$DEVICE"
else
  # BIOS layout:
  # 1 -> OS partition
  # 2 -> Home partition
  echo -e "o\nn\n\n\n\n+${OS_SIZE}\nn\n\n\n\n\na\n1\nw\n" | fdisk "$DEVICE"
fi

# Debug
echo "--------------------------------------------------------------------------------"
echo "The '$DEVICE' device has been partitioned." 
fdisk --list "$DEVICE"
echo "================================================================================"

# Build the full partition path for a given device and partition number
# Handles naming differences between device types:
# - Devices ending with a digit (e.g. /dev/nvme0n1) → use 'p' separator (/dev/nvme0n1p1)
# - Devices not ending with a digit (e.g. /dev/sda) → no separator (/dev/sda1)
# 
# Args:
#   $1 -> partition number (e.g. 1, 2, ...)
#
# Uses global:
#   DEVICE -> base device path
#
# Output:
#   Prints the full partition path (e.g. /dev/sda1 or /dev/nvme0n1p1)
partition_path() {
  local partition_number="$1"

  if [[ "$DEVICE" =~ [0-9]$ ]]; then
    printf "%sp%s" "$DEVICE" "$partition_number"
  else
    printf "%s%s" "$DEVICE" "$partition_number"
  fi
}

# Partition formatting
if [[ "$BOOT" == "uefi" ]]; then
  # Create a FAT32 filesystem on partition 1 (typically for EFI system partition)
  mkfs.fat -F 32 "$(partition_path 1)"

  # Create an ext4 filesystem on partition 2 (usually for the root filesystem)
  mkfs.ext4 "$(partition_path 2)"
  
  # Store the path of partition 3 in a variable (e.g., for /home)
  home_partition="$(partition_path 3)"
else
  # Create an ext4 filesystem on partition 1 (usually for the root filesystem)
  mkfs.ext4 "$(partition_path 1)"
  
  # Store the path of partition 3 in a variable (e.g., for /home)
  home_partition="$(partition_path 2)"
fi

if [[ -n "$HOME_ENCRYPTION" ]]; then
  # Write the encryption password (without newline) to stdout and pipe it to cryptsetup
  # Initialize LUKS encryption on partition 2 in batch mode (no interactive prompts)
  # "-" tells cryptsetup to read the passphrase from stdin
  echo -n "$HOME_ENCRYPTION" | cryptsetup luksFormat --batch-mode "$home_partition" -

  # Send the password again via stdin to unlock (open) the encrypted partition
  # Creates a mapped device under /dev/mapper/$CRYPT_NAME
  echo -n "$HOME_ENCRYPTION" | cryptsetup open "$home_partition" "$CRYPT_NAME" -

  # Create an ext4 filesystem on the opened (decrypted) mapped device
  mkfs.ext4 "/dev/mapper/$CRYPT_NAME"

  # Close the mapped encrypted device (lock it again)
  cryptsetup close "$CRYPT_NAME"
else
  mkfs.ext4 "$home_partition"
fi

echo "--------------------------------------------------------------------------------"
echo "The partitions on '$DEVICE' device have been formatted." 
lsblk --fs "$DEVICE"
echo "================================================================================"

# Partition mounting
mkdir -p "$ARCH_MOUNT_POINT"

if [[ "$BOOT" == "uefi" ]]; then
  root_partition="$(partition_path 2)"
  efi_partition="$(partition_path 1)"
else
  root_partition="$(partition_path 1)"
fi

mount "$root_partition" "$ARCH_MOUNT_POINT"

if [[ -n "$HOME_ENCRYPTION" ]]; then
  echo -n "$HOME_ENCRYPTION" | cryptsetup open "$home_partition" "$CRYPT_NAME" -
  mount --mkdir /dev/mapper/$CRYPT_NAME "$ARCH_MOUNT_POINT/home"
else
  mount --mkdir "$home_partition" "$ARCH_MOUNT_POINT/home"
fi

if [[ "$BOOT" == "uefi" ]]; then
  mount --mkdir "$efi_partition" "$ARCH_MOUNT_POINT/boot/efi"
fi

echo "--------------------------------------------------------------------------------"
echo "Partitions on '$DEVICE' have been mounted."
echo "Root mounted on $ARCH_MOUNT_POINT from $root_partition"

if [[ -n "$HOME_ENCRYPTION" ]]; then
  echo "Home partition '$home_partition' opened as '$CRYPT_NAME' and mounted on $ARCH_MOUNT_POINT/home"
else
  echo "Home mounted on $ARCH_MOUNT_POINT/home from $home_partition"
fi

if [[ "$BOOT" == "uefi" ]]; then
  echo "EFI mounted on $ARCH_MOUNT_POINT/boot/efi from $efi_partition"
fi

echo "================================================================================"
