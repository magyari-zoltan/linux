#!/bin/bash

# Default values
DEVICE="/dev/sda"
OS_SIZE="50G"
HOME_ENCRYPTION=""

# Shows help, examples, and defaults. Called on --help or invalid input.
usage() {
  cat <<EOF
Usage: $(basename "$0") [OPTIONS]

Options:
  --device <path>             Target disk device (default: /dev/sda)
  --os-size <size>            Size of OS partition (default: 50G)
  --home-encryption <value>   Password to enable home encryption
  -h, --help                  Show this help and exit

Examples:
  $(basename "$0") --device /dev/sdb --os-size 100G
  $(basename "$0") --home-encryption secret

WARNING:
  This script modifies disks → DATA LOSS ⚠️
EOF
}

# Argument parsing
while [[ $# -gt 0 ]]; do
  case "$1" in
    --device)
      [[ -z "$2" ]] && echo "Missing value for --device" && usage && exit 1
      DEVICE="$2"
      shift 2
      ;;
    --os-size)
      [[ -z "$2" ]] && echo "Missing value for --os-size" && usage && exit 1
      OS_SIZE="$2"
      shift 2
      ;;
    --home-encryption)
      [[ -z "$2" ]] && echo "Missing value for --home-encryption" && usage && exit 1
      HOME_ENCRYPTION="$2"
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    -*)
      echo "Unknown option: $1"
      usage
      exit 1
      ;;
    *)
      echo "Unexpected argument: $1"
      usage
      exit 1
      ;;
  esac
done

# Debug
echo "--------------------------------------------------------------------------------"
echo "Device: $DEVICE"
echo "OS size: $OS_SIZE"
echo "Home encryption: ${HOME_ENCRYPTION:-disabled}"
echo "================================================================================"

# This command automatically partitions a disk using fdisk.
# The lines sent by echo correspond to fdisk's interactive command:
#
# o        -> create a new empty DOS partition table
# n        -> create a new partition
# +50G     -> partition size: 50GB
# n        -> create another partition (using remaining space)
# (empty)  -> accept default valuse (primary partition, full remaining size)
# a        -> set boot flag (mark partition as active)
# 1        -> make the first partition bootable
# w        -> write changes and exit
echo -e "o\nn\n\n\n\n+${OS_SIZE}\nn\n\n\n\n\na\n1\nw\n" | fdisk $DEVICE

# Debug
echo "--------------------------------------------------------------------------------"
echo "The '$DEVICE' device has been partitioned." 
fdisk --list $DEVICE
echo "================================================================================"

# Create ext4 filesystems on the first and second partitions of the disk

# ${DEVICE}1 -> first partition
mkfs.ext4 ${DEVICE}1

# ${DEVICE}2 -> second partition
mkfs.ext4 ${DEVICE}2

echo "--------------------------------------------------------------------------------"
echo "The partitions on '$DEVICE' device have been formatted." 
lsblk --fs $DEVICE
echo "================================================================================"
